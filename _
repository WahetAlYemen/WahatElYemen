<script>
// Stars canvas
(function(){
  const c = document.getElementById('starsCanvas');
  const ctx = c.getContext('2d');
  let W, H, stars = [];
  function resize(){
    W = c.width = window.innerWidth;
    H = c.height = window.innerHeight;
  }
  function makeStar(){
    return {
      x: Math.random()*W, y: Math.random()*H,
      r: Math.random()*1.2+0.3,
      a: Math.random(), da: (Math.random()-0.5)*0.008,
      sp: Math.random()*0.15+0.02
    };
  }
  resize();
  for(let i=0;i<120;i++) stars.push(makeStar());
  window.addEventListener('resize', resize);
  function draw(){
    ctx.clearRect(0,0,W,H);
    stars.forEach(s=>{
      s.a = Math.max(0.05, Math.min(0.9, s.a+s.da));
      if(Math.random()<0.002) s.da *= -1;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI*2);
      ctx.fillStyle = `rgba(245,217,138,${s.a})`;
      ctx.fill();
    });
    requestAnimationFrame(draw);
  }
  draw();
})();

